{% comment %}
  Reusable Plan C header. `announcement` is HTML (richtext from settings, or built with Liquid).

  Logo: pass `logo` to override; otherwise uses `settings.logo` from Theme settings > Logo.
  Pass `logo_max_width` and `logo_max_height` (px) to control size (defaults 200×56 if omitted).

  From custom Liquid:
    {% render 'plan-c-header', logo: settings.logo, logo_max_width: 240, logo_max_height: 64, ... %}

  Navigation typography (optional): nav_font (font_picker = font-family name only; load files in theme CSS/fonts),
  nav_font_size, nav_font_weight, nav_letter_spacing, nav_text_transform, nav_line_height, nav_link_color, nav_link_hover_color

  Spacing (optional): section_margin_top, section_margin_bottom, announcement_padding_y/x, bar_padding_y/x,
  nav_row_padding_y/x (px; drives CSS variables on this root)
{% endcomment %}

{% liquid
  assign logo_src = logo
  if logo_src == blank and settings.logo != blank
    assign logo_src = settings.logo
  endif
  assign logo_w = logo_max_width | default: 200 | times: 1
  assign logo_h = logo_max_height | default: 56 | times: 1
  assign logo_url_width = logo_w | times: 2
  if logo_url_width > 800
    assign logo_url_width = 800
  endif
  if logo_url_width < 80
    assign logo_url_width = 80
  endif
  assign logo_sizes = '(max-width: 749px) 45vw, ' | append: logo_w | append: 'px'

  assign nav_ff = ''
  if nav_font != blank
    assign nav_ff = nav_font.family | append: ', ' | append: nav_font.fallback_families
  endif

  assign nav_ls_key = nav_letter_spacing | default: 'wide'
  case nav_ls_key
    when 'tight'
      assign nav_ls_em = '0.02em'
    when 'normal'
      assign nav_ls_em = '0.04em'
    when 'wide'
      assign nav_ls_em = '0.06em'
    when 'extra'
      assign nav_ls_em = '0.12em'
    else
      assign nav_ls_em = '0em'
  endcase

  assign nav_tf = nav_text_transform | default: 'uppercase'
  assign nav_fw = nav_font_weight | default: '600'
  assign nav_fs = nav_font_size | default: 13
  assign nav_lh = nav_line_height | default: 1.4
  assign nav_lc = nav_link_color | default: '#1a1a1a'
  assign nav_lhc = nav_link_hover_color | default: '#000000'

  assign sec_mt = section_margin_top | default: 0
  assign sec_mb = section_margin_bottom | default: 0
  assign ann_py = announcement_padding_y | default: 10
  assign ann_px = announcement_padding_x | default: 16
  assign bar_py = bar_padding_y | default: 16
  assign bar_px = bar_padding_x | default: 20
  assign navr_py = nav_row_padding_y | default: 14
  assign navr_px = nav_row_padding_x | default: 16
%}

<div
  class="plan-c-header"
  style="
    --plan-c-header-mt: {{ sec_mt }}px;
    --plan-c-header-mb: {{ sec_mb }}px;
    --plan-c-announce-py: {{ ann_py }}px;
    --plan-c-announce-px: {{ ann_px }}px;
    --plan-c-bar-py: {{ bar_py }}px;
    --plan-c-bar-px: {{ bar_px }}px;
    --plan-c-header-nav-py: {{ navr_py }}px;
    --plan-c-header-nav-px: {{ navr_px }}px;
    {% if announcement_bg != blank %}--plan-c-announcement-bg: {{ announcement_bg }};{% endif %}
    {% if bar_background != blank %}--plan-c-header-bar-bg: {{ bar_background }};{% endif %}
    {% if bar_border_color != blank %}--plan-c-header-bar-border: {{ bar_border_color }};{% endif %}
  "
>
  {% if announcement != blank %}
    <div class="plan-c-header__announcement rte">
      {{ announcement }}
    </div>
  {% endif %}

  <div class="plan-c-header__bar{% if sticky_header %} plan-c-header__bar--sticky{% endif %}">
    {% if logo_src != blank %}
      {% liquid
        assign logo_alt = logo_src.alt | default: shop.name
      %}
      <a
        class="plan-c-header__logo plan-c-header__logo--image"
        href="{{ routes.root_url }}"
        style="--plan-c-logo-max-w: {{ logo_w }}px; --plan-c-logo-max-h: {{ logo_h }}px;"
      >
        {{
          logo_src
          | image_url: width: logo_url_width
          | image_tag:
            class: 'plan-c-header__logo-img',
            widths: '120, 180, 240, 360, 480, 600, 800',
            sizes: logo_sizes,
            alt: logo_alt,
            loading: 'eager',
            fetchpriority: 'high'
        }}
      </a>
    {% else %}
      <a class="plan-c-header__logo plan-c-header__logo--text" href="{{ routes.root_url }}">
        {% if logo_text_plan != blank or logo_text_c != blank %}
          <span class="plan-c-header__logo-plan">{{ logo_text_plan | escape }}</span><span class="plan-c-header__logo-c">{{ logo_text_c | escape }}</span>
        {% else %}
          <span class="plan-c-header__logo-plan">{{ shop.name | escape }}</span>
        {% endif %}
      </a>
    {% endif %}

    <div class="plan-c-header__actions">
      <div class="plan-c-header__icons" role="group" aria-label="Account, search, and cart">
        <a class="plan-c-header__icon-link" href="{{ routes.cart_url }}" aria-label="Shopping cart">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </a>
        <a class="plan-c-header__icon-link" href="{{ routes.search_url }}" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </a>
        <a class="plan-c-header__icon-link" href="{{ routes.account_url }}" aria-label="Account">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </a>
      </div>

      {% if cta_text != blank %}
        <a class="plan-c-header__cta" href="{% if cta_url != blank %}{{ cta_url }}{% else %}#{% endif %}">
          {{ cta_text | escape }}
        </a>
      {% endif %}
    </div>
  </div>

  {% if menu != blank and menu.links != blank and menu.links.size > 0 %}
    <nav
      class="plan-c-header__nav"
      aria-label="Primary navigation"
      style="
        {% if nav_ff != blank %}--plan-c-nav-font-family: {{ nav_ff }};{% endif %}
        --plan-c-nav-font-size: {{ nav_fs }}px;
        --plan-c-nav-font-weight: {{ nav_fw }};
        --plan-c-nav-letter-spacing: {{ nav_ls_em }};
        --plan-c-nav-text-transform: {{ nav_tf }};
        --plan-c-nav-line-height: {{ nav_lh }};
        --plan-c-nav-color: {{ nav_lc }};
        --plan-c-nav-hover-color: {{ nav_lhc }};
      "
    >
      {% for link in menu.links %}
        <a href="{{ link.url }}">{{ link.title | escape }}</a>
      {% endfor %}
    </nav>
  {% endif %}
</div>
